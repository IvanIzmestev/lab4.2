#include <iostream>

struct Node {
    int data;
    Node* next;
};

Node* head = nullptr;

extern "C" {

// ============= БАЗОВЫЕ ФУНКЦИИ =============

__declspec(dllexport) void add_first(int value) {
    Node* new_node = new Node{value, head};
    head = new_node;
}

__declspec(dllexport) void remove_first() {
    if (!head) return;
    Node* temp = head;
    head = head->next;
    delete temp;
}

__declspec(dllexport) int get_count() {
    int count = 0;
    Node* current = head;
    while (current) {
        count++;
        current = current->next;
    }
    return count;
}

__declspec(dllexport) int get_value(int index, int* out) {
    Node* current = head;
    int i = 0;
    while (current) {
        if (i == index) {
            *out = current->data;
            return 1;
        }
        current = current->next;
        i++;
    }
    return 0;
}

__declspec(dllexport) void clear_list() {
    while (head) {
        Node* temp = head;
        head = head->next;
        delete temp;
    }
}

// ============= ОПЕРАЦИИ ПО ИНДЕКСУ =============

__declspec(dllexport) int add_by_index(int index, int value) {
    if (index < 0) return 0;
    
    if (index == 0) {
        add_first(value);
        return 1;
    }
    
    Node* current = head;
    int i = 0;
    while (current && i < index - 1) {
        current = current->next;
        i++;
    }
    
    if (!current) return 0;
    
    Node* new_node = new Node{value, current->next};
    current->next = new_node;
    return 1;
}

__declspec(dllexport) int remove_by_index(int index) {
    if (index < 0) return 0;
    
    if (index == 0) {
        if (head) {
            remove_first();
            return 1;
        }
        return 0;
    }
    
    Node* current = head;
    int i = 0;
    while (current && i < index - 1) {
        current = current->next;
        i++;
    }
    
    if (!current || !current->next) return 0;
    
    Node* temp = current->next;
    current->next = temp->next;
    delete temp;
    return 1;
}

__declspec(dllexport) int remove_by_condition(int value, int mode) {
    int removed = 0;
    Node* current = head;
    Node* prev = nullptr;
    
    while (current) {
        bool should_remove = false;
        
        switch(mode) {
            case 1: should_remove = (current->data < value); break;
            case 2: should_remove = (current->data == value); break;
            case 3: should_remove = (current->data > value); break;
            case 4: should_remove = (current->data <= value); break;
            default: return 0;
        }
        
        if (should_remove) {
            if (prev) {
                prev->next = current->next;
                delete current;
                current = prev->next;
            } else {
                head = current->next;
                delete current;
                current = head;
            }
            removed++;
        } else {
            prev = current;
            current = current->next;
        }
    }
    
    return removed;
}

// ============= ОПЕРАЦИИ С КОНЦАМИ =============

__declspec(dllexport) void add_last(int value) {
    if (!head) {
        add_first(value);
        return;
    }
    
    Node* current = head;
    while (current->next) {
        current = current->next;
    }
    current->next = new Node{value, nullptr};
}

__declspec(dllexport) void remove_last() {
    if (!head) return;
    
    if (!head->next) {
        delete head;
        head = nullptr;
        return;
    }
    
    Node* current = head;
    while (current->next && current->next->next) {
        current = current->next;
    }
    
    delete current->next;
    current->next = nullptr;
}

// ============= ПРЕОБРАЗОВАНИЯ =============

__declspec(dllexport) void reverse_list() {
    if (!head || !head->next) return;
    
    Node* prev = nullptr;
    Node* current = head;
    Node* next = nullptr;
    
    while (current) {
        next = current->next;
        current->next = prev;
        prev = current;
        current = next;
    }
    head = prev;
}

__declspec(dllexport) void sort_list() {
    if (!head || !head->next) return;
    
    bool swapped;
    Node* current;
    Node* last = nullptr;
    
    do {
        swapped = false;
        current = head;
        
        while (current->next != last) {
            if (current->data > current->next->data) {
                int temp = current->data;
                current->data = current->next->data;
                current->next->data = temp;
                swapped = true;
            }
            current = current->next;
        }
        last = current;
    } while (swapped);
}

__declspec(dllexport) void remove_duplicates() {
    if (!head || !head->next) return;
    
    sort_list();
    
    Node* current = head;
    while (current && current->next) {
        if (current->data == current->next->data) {
            Node* temp = current->next;
            current->next = temp->next;
            delete temp;
        } else {
            current = current->next;
        }
    }
}

// ============= ПОИСК И АНАЛИЗ =============

__declspec(dllexport) int get_min(int* out) {
    if (!head) return 0;
    
    int min_val = head->data;
    Node* current = head->next;
    
    while (current) {
        if (current->data < min_val) {
            min_val = current->data;
        }
        current = current->next;
    }
    
    *out = min_val;
    return 1;
}

__declspec(dllexport) int get_max(int* out) {
    if (!head) return 0;
    
    int max_val = head->data;
    Node* current = head->next;
    
    while (current) {
        if (current->data > max_val) {
            max_val = current->data;
        }
        current = current->next;
    }
    
    *out = max_val;
    return 1;
}

__declspec(dllexport) int find_first(int value) {
    Node* current = head;
    int index = 0;
    
    while (current) {
        if (current->data == value) {
            return index;
        }
        current = current->next;
        index++;
    }
    
    return -1;
}

}
