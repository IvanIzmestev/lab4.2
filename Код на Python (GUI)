import ctypes
from ctypes import c_int, POINTER
import os


class _Node:
    def __init__(self, data):
        self.data = data
        self.next = None


class _LinkedList:
    def __init__(self):
        self.head = None
        self._size = 0

    def add_first(self, value):
        new_node = _Node(value)
        new_node.next = self.head
        self.head = new_node
        self._size += 1
        return True, "Элемент добавлен в начало"

    def remove_first(self):
        if not self.head:
            return False, "Список пуст"

        self.head = self.head.next
        self._size -= 1
        return True, "Первый элемент удален"

    def get_count(self):
        return self._size

    def get_all_values(self):
        values = []
        current = self.head
        while current:
            values.append(current.data)
            current = current.next
        return values

    def get_value(self, index):
        if index < 0 or index >= self._size:
            return None

        current = self.head
        for _ in range(index):
            current = current.next
        return current.data

    def clear(self):
        self.head = None
        self._size = 0
        return True, "Список очищен"

    def add_by_index(self, index, value):
        if index < 0 or index > self._size:
            return False, f"Индекс {index} вне диапазона [0, {self._size}]"

        if index == 0:
            return self.add_first(value)

        new_node = _Node(value)
        current = self.head
        for _ in range(index - 1):
            current = current.next

        new_node.next = current.next
        current.next = new_node
        self._size += 1

        return True, f"Элемент добавлен по индексу {index}"

    def remove_by_index(self, index):
        if index < 0 or index >= self._size:
            return False, f"Индекс {index} вне диапазона [0, {self._size - 1}]"

        if index == 0:
            return self.remove_first()

        current = self.head
        for _ in range(index - 1):
            current = current.next

        current.next = current.next.next
        self._size -= 1

        return True, f"Элемент по индексу {index} удален"

    def remove_by_condition(self, value, mode):
        if self._size == 0:
            return False, "Список пуст"

        removed = 0
        current = self.head
        prev = None

        while current:
            should_remove = False

            if mode == 1:  # меньше
                should_remove = (current.data < value)
            elif mode == 2:  # равно
                should_remove = (current.data == value)
            elif mode == 3:  # больше
                should_remove = (current.data > value)
            elif mode == 4:
                should_remove = (current.data <= value)
            else:
                return False, "Неверный режим удаления (1 - меньше, 2 - равно, 3 - больше)"

            if should_remove:
                if prev:
                    prev.next = current.next
                else:
                    self.head = current.next
                current = current.next
                self._size -= 1
                removed += 1
            else:
                prev = current
                current = current.next

        mode_text = {1: "меньше", 2: "равно", 3: "больше"}.get(mode)

        if removed > 0:
            return True, f"Удалено {removed} элементов {mode_text} {value}"
        else:
            return True, f"Элементы {mode_text} {value} не найдены"

    def add_last(self, value):
        if not self.head:
            return self.add_first(value)

        current = self.head
        while current.next:
            current = current.next

        current.next = _Node(value)
        self._size += 1
        return True, "Элемент добавлен в конец"

    def remove_last(self):
        if not self.head:
            return False, "Список пуст"

        if not self.head.next:
            self.head = None
            self._size = 0
            return True, "Последний элемент удален"

        current = self.head
        while current.next and current.next.next:
            current = current.next

        current.next = None
        self._size -= 1
        return True, "Последний элемент удален"

    def reverse(self):
        if not self.head or not self.head.next:
            return True, "Список уже развернут"

        prev = None
        current = self.head

        while current:
            next_temp = current.next
            current.next = prev
            prev = current
            current = next_temp

        self.head = prev
        return True, "Список развернут"

    def sort(self):
        if self._size <= 1:
            return True, "Список уже отсортирован"

        for i in range(self._size - 1):
            current = self.head
            for j in range(self._size - 1 - i):
                if current.data > current.next.data:
                    current.data, current.next.data = current.next.data, current.data
                current = current.next

        return True, "Список отсортирован"

    def find_min(self):
        if not self.head:
            return None, "Список пуст"

        min_val = self.head.data
        current = self.head.next

        while current:
            if current.data < min_val:
                min_val = current.data
            current = current.next

        return min_val, f"Минимальное значение: {min_val}"

    def find_max(self):
        if not self.head:
            return None, "Список пуст"

        max_val = self.head.data
        current = self.head.next

        while current:
            if current.data > max_val:
                max_val = current.data
            current = current.next

        return max_val, f"Максимальное значение: {max_val}"

    def remove_duplicates(self):
        if self._size <= 1:
            return True, "Нет дубликатов для удаления"

        removed = 0
        current = self.head

        # Внешний цикл: проходим по каждому элементу списка
        while current:
            # Внутренний цикл: ищем дубликаты текущего элемента во всем списке
            runner = self.head
            prev = None

            while runner:
                # Если находим дубликат (значение равно текущему, но это не тот же самый узел)
                if runner.data == current.data and runner != current:
                    # Удаляем дубликат
                    if prev:
                        prev.next = runner.next
                    else:
                        self.head = runner.next
                    runner = runner.next
                    self._size -= 1
                    removed += 1
                else:
                    prev = runner
                    runner = runner.next

            current = current.next

        if removed > 0:
            return True, f"Удалено {removed} дубликатов"
        else:
            return True, "Дубликаты не найдены"
    def find_first(self, value):
        current = self.head
        index = 0

        while current:
            if current.data == value:
                return index, f"Значение {value} найдено на индексе {index}"
            current = current.next
            index += 1

        return -1, f"Значение {value} не найдено"


