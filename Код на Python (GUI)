class ListOperations:
    # Режимы работы
    MODE_DYNAMIC = "dynamic"
    MODE_STL = "stl"
    MODE_PYTHON = "python"

    def __init__(self, mode=MODE_DYNAMIC, dll_path="cpp_module/"):

        self.mode = mode

        if mode == self.MODE_PYTHON:
            self._python_ops = _PythonListOperations()
            self.lib = None

            self.has_add_by_index = True
            self.has_remove_by_index = True
            self.has_remove_by_condition = True
            self.has_add_last = True
            self.has_remove_last = True
            self.has_reverse = True
            self.has_sort = True
            self.has_get_min = True
            self.has_get_max = True
            self.has_remove_duplicates = True
            self.has_find_first = True

        else:
            self._python_ops = None
            self._init_cpp(mode, dll_path)

    def _init_cpp(self, mode, dll_path):
        current_dir = os.path.dirname(os.path.abspath(__file__))
        full_dll_path = os.path.join(current_dir, dll_path)

        if mode == self.MODE_DYNAMIC:
            dll_file = "list_dynamic.dll"
        elif mode == self.MODE_STL:
            dll_file = "list_stl.dll"
        else:
            raise ValueError(f"Неизвестный режим: {mode}")

        full_dll_file = os.path.join(full_dll_path, dll_file)

        if not os.path.exists(full_dll_file):
            raise Exception(f"Файл DLL не найден: {full_dll_file}")

        try:
            self.lib = ctypes.CDLL(full_dll_file)
        except Exception as e:
            raise Exception(f"Не удалось загрузить DLL {dll_file}: {str(e)}")

        self._setup_cpp_signatures()
        self._check_cpp_functions()

    def _setup_cpp_signatures(self):
        """Настройка сигнатур для всех функций C++ DLL"""

        # Базовые функции
        if hasattr(self.lib, "add_first"):
            self.lib.add_first.argtypes = [c_int]
            self.lib.add_first.restype = None

        if hasattr(self.lib, "remove_first"):
            self.lib.remove_first.argtypes = []
            self.lib.remove_first.restype = None

        if hasattr(self.lib, "get_count"):
            self.lib.get_count.argtypes = []
            self.lib.get_count.restype = c_int

        if hasattr(self.lib, "get_value"):
            self.lib.get_value.argtypes = [c_int, POINTER(c_int)]
            self.lib.get_value.restype = c_int

        if hasattr(self.lib, "clear_list"):
            self.lib.clear_list.argtypes = []
            self.lib.clear_list.restype = None

        # Дополнительные функции (должны быть в Dynamic и STL)
        if hasattr(self.lib, "add_by_index"):
            self.lib.add_by_index.argtypes = [c_int, c_int]
            self.lib.add_by_index.restype = c_int

        if hasattr(self.lib, "remove_by_index"):
            self.lib.remove_by_index.argtypes = [c_int]
            self.lib.remove_by_index.restype = c_int

        if hasattr(self.lib, "remove_by_condition"):
            self.lib.remove_by_condition.argtypes = [c_int, c_int]
            self.lib.remove_by_condition.restype = c_int

        if hasattr(self.lib, "add_last"):
            self.lib.add_last.argtypes = [c_int]
            self.lib.add_last.restype = None

        if hasattr(self.lib, "remove_last"):
            self.lib.remove_last.argtypes = []
            self.lib.remove_last.restype = None

        if hasattr(self.lib, "reverse_list"):
            self.lib.reverse_list.argtypes = []
            self.lib.reverse_list.restype = None

        if hasattr(self.lib, "sort_list"):
            self.lib.sort_list.argtypes = []
            self.lib.sort_list.restype = None

        if hasattr(self.lib, "get_min"):
            self.lib.get_min.argtypes = [POINTER(c_int)]
            self.lib.get_min.restype = c_int

        if hasattr(self.lib, "get_max"):
            self.lib.get_max.argtypes = [POINTER(c_int)]
            self.lib.get_max.restype = c_int

        if hasattr(self.lib, "remove_duplicates"):
            self.lib.remove_duplicates.argtypes = []
            self.lib.remove_duplicates.restype = None

        if hasattr(self.lib, "find_first"):
            self.lib.find_first.argtypes = [c_int]
            self.lib.find_first.restype = c_int

    def _check_cpp_functions(self):
        """Проверка наличия дополнительных функций в C++ DLL"""
        self.has_add_by_index = hasattr(self.lib, "add_by_index")
        self.has_remove_by_index = hasattr(self.lib, "remove_by_index")
        self.has_remove_by_condition = hasattr(self.lib, "remove_by_condition")
        self.has_add_last = hasattr(self.lib, "add_last")
        self.has_remove_last = hasattr(self.lib, "remove_last")
        self.has_reverse = hasattr(self.lib, "reverse_list")
        self.has_sort = hasattr(self.lib, "sort_list")
        self.has_get_min = hasattr(self.lib, "get_min")
        self.has_get_max = hasattr(self.lib, "get_max")
        self.has_remove_duplicates = hasattr(self.lib, "remove_duplicates")
        self.has_find_first = hasattr(self.lib, "find_first")

        # Отладочный вывод (можно убрать после проверки)
        print(f"[DEBUG] Загружен модуль: {self.mode}")
        print(f"[DEBUG] has_add_by_index: {self.has_add_by_index}")
        print(f"[DEBUG] has_sort: {self.has_sort}")
        print(f"[DEBUG] has_reverse: {self.has_reverse}")

    def add_first(self, value):
        if self.mode == self.MODE_PYTHON:
            return self._python_ops.add_first(value)
        else:
            try:
                self.lib.add_first(value)
                return True, "Элемент добавлен в начало"
            except Exception as e:
                return False, f"Ошибка: {str(e)}"

    def remove_first(self):
